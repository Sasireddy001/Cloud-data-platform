# Copy this file to .env and fill in the values from Terraform outputs
# Event Hubs
EVENT_HUB_NAMESPACE_NAME=cloud-event-hubs-ns-dev
EVENT_HUB_NAME=events
EVENT_HUB_CONNECTION_STRING=Endpoint=sb://<namespace>.servicebus.windows.net/;SharedAccessKeyName=RootManageSharedAccessKey;SharedAccessKey=<key>
EVENT_HUB_CONSUMER_GROUP=$Default

# Databricks
DATABRICKS_HOST=https://<workspace>.azuredatabricks.net
DATABRICKS_TOKEN=<databricks-personal-access-token>
DATABRICKS_CLUSTER_ID=<cluster-id>

# Storage
STORAGE_ACCOUNT_NAME=<storage-account-name>
STORAGE_ACCOUNT_KEY=<storage-account-key>
DELTA_PATH=abfss://delta@<storage-account>.dfs.core.windows.net/delta
CHECKPOINT_PATH=abfss://delta@<storage-account>.dfs.core.windows.net/checkpoints

# Streaming job tuning
TRIGGER_INTERVAL=10 seconds
MAX_OFFSETS_PER_TRIGGER=10000
WATERMARK_SECONDS=120
